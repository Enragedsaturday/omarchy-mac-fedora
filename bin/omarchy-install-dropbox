#!/bin/bash

# The official Dropbox Linux client is x86_64-only — there is no aarch64 (Apple
# Silicon) build, so it cannot run on Fedora Asahi Remix.

echo "Dropbox does not ship an aarch64 Linux client, so it can't be installed on this Mac."
echo
echo "Working alternative: Maestral, an open-source Dropbox client that runs on aarch64:"
echo "  pipx install maestral        # CLI + sync daemon"
echo "  pipx install maestral-gui    # optional tray GUI"
echo "Then run 'maestral start' and authenticate via the web."
echo
gum confirm "Install Maestral now via pipx?" || exit 0

if ! command -v pipx >/dev/null 2>&1; then
  omarchy-pkg-add pipx
fi
pipx install maestral
echo "Run 'maestral start' to begin syncing."
