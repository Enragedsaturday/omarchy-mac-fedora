#!/bin/bash
set -e

# Reinstall all default Omarchy packages from the Fedora package list.

OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
package_file="$OMARCHY_PATH/install/omarchy-base.packages.fedora"

# Read package names, skipping comments, blanks, and the optional-section marker.
mapfile -t packages < <(grep -vE '^#|^$|^OPTIONAL:$' "$package_file")

echo "Reinstalling ${#packages[@]} packages via dnf..."

# --allowerasing lets the Hyprland (lionheartp, priority=10) packages replace any
# conflicting base-repo builds, matching the behavior of fedora_install_package.
sudo dnf install -y --refresh --allowerasing "${packages[@]}"
